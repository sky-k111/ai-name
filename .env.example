# Never commit real credentials. Production must replace every placeholder.
ENVIRONMENT=development
DATABASE_URL=sqlite:///./naming.db
SECRET_KEY=replace-with-a-random-secret-at-least-32-characters
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password
DEEPSEEK_API_KEY=
ENABLE_DEMO_RECHARGE=false

# Optional SMTP settings for password reset and email binding.
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
